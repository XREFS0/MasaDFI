<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MasaDFI"
        mc:Ignorable="d"
        Title="MASA DFI - Digital Forensics Investigator" Height="700" Width="1200" WindowStartupLocation="CenterScreen" Background="#000000" Foreground="#00FF00" FontFamily="Consolas" Icon="logo.ico">
    <Window.Resources>
        <!-- Sidebar Button Style -->
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Padding" Value="20,15" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#00FF00" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Navigation -->
        <Border Grid.Column="0" Background="#0A0A0A" BorderBrush="#00FF00" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,20,0,0">
                    <TextBlock Text="MASA DFI" FontSize="28" FontWeight="Bold" Foreground="#00C896" HorizontalAlignment="Center" Margin="0,0,0,30" />
                    
                    <Button x:Name="btnDashboard" Content="Dashboard" Style="{StaticResource SidebarButton}" Click="NavButton_Click" Tag="Dashboard" />
                    <Button x:Name="btnEventLogs" Content="Event Log Analyzer" Style="{StaticResource SidebarButton}" Click="NavButton_Click" Tag="EventLogs" />
                    <Button x:Name="btnBrowser" Content="Browser History" Style="{StaticResource SidebarButton}" Click="NavButton_Click" Tag="Browser" />
                    <Button x:Name="btnUSB" Content="USB Device History" Style="{StaticResource SidebarButton}" Click="NavButton_Click" Tag="USB" />
                    <Button x:Name="btnTimeline" Content="Timeline Explorer" Style="{StaticResource SidebarButton}" Click="NavButton_Click" Tag="Timeline" />
                    <Button x:Name="btnRecovery" Content="File Recovery" Style="{StaticResource SidebarButton}" Click="NavButton_Click" Tag="Recovery" />
                    <Button x:Name="btnSuspicious" Content="Suspicious File Scanner" Style="{StaticResource SidebarButton}" Click="NavButton_Click" Tag="Suspicious" />
                    <Button x:Name="btnPrefetch" Content="Prefetch Analyzer" Style="{StaticResource SidebarButton}" Click="NavButton_Click" Tag="Prefetch" />
                    <Button x:Name="btnAdsScanner" Content="ADS Scanner" Style="{StaticResource SidebarButton}" Click="NavButton_Click" Tag="AdsScanner" />
                    <Button x:Name="btnJumpLists" Content="Jump Lists Analyzer" Style="{StaticResource SidebarButton}" Click="NavButton_Click" Tag="JumpLists" />
                    <Button x:Name="btnDnsCache" Content="DNS Cache Viewer" Style="{StaticResource SidebarButton}" Click="NavButton_Click" Tag="DnsCache" />
                    <Button x:Name="btnServices" Content="Services Analyzer" Style="{StaticResource SidebarButton}" Click="NavButton_Click" Tag="Services" />
                    <Button x:Name="btnSystem" Content="System Analyzers" Style="{StaticResource SidebarButton}" Click="NavButton_Click" Tag="System" />
                    <Button x:Name="btnExport" Content="Evidence Export" Style="{StaticResource SidebarButton}" Click="NavButton_Click" Tag="Export" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" Background="#000000">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" />
        </Grid>
    </Grid>
</Window>
