<Application x:Class="Application"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MasaDFI"
             StartupUri="Views/SplashWindow.xaml">
    <Application.Resources>
        <!-- Global Colors -->
        <SolidColorBrush x:Key="HackerGreen" Color="#00FF00" />
        <SolidColorBrush x:Key="HackerBg" Color="#050505" />
        <SolidColorBrush x:Key="HackerBgAlt" Color="#0A0A0A" />

        <!-- DataGrid Style -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource HackerBg}" />
            <Setter Property="Foreground" Value="{StaticResource HackerGreen}" />
            <Setter Property="RowBackground" Value="{StaticResource HackerBg}" />
            <Setter Property="AlternatingRowBackground" Value="{StaticResource HackerBgAlt}" />
            <Setter Property="BorderBrush" Value="{StaticResource HackerGreen}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalGridLinesBrush" Value="#004400" />
            <Setter Property="VerticalGridLinesBrush" Value="#004400" />
            <Setter Property="HeadersVisibility" Value="Column" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#002200" />
            <Setter Property="Foreground" Value="{StaticResource HackerGreen}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="5" />
            <Setter Property="BorderBrush" Value="{StaticResource HackerGreen}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="{StaticResource HackerGreen}" />
            <Setter Property="Background" Value="{StaticResource HackerBg}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#003300" />
                    <Setter Property="Foreground" Value="#00FF00" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{StaticResource HackerGreen}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="5" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="#00FF00" />
                    <Setter Property="BorderThickness" Value="0" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TabItem Style -->
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="{StaticResource HackerBgAlt}" />
            <Setter Property="Foreground" Value="#00AA00" />
            <Setter Property="BorderBrush" Value="{StaticResource HackerGreen}" />
            <Setter Property="BorderThickness" Value="1,1,1,0" />
            <Setter Property="Padding" Value="10,5" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource HackerBg}" />
                    <Setter Property="Foreground" Value="{StaticResource HackerGreen}" />
                    <Setter Property="FontWeight" Value="Bold" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource HackerBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource HackerGreen}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <!-- TextBox and ComboBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource HackerBgAlt}" />
            <Setter Property="Foreground" Value="{StaticResource HackerGreen}" />
            <Setter Property="BorderBrush" Value="{StaticResource HackerGreen}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="5" />
            <Setter Property="CaretBrush" Value="{StaticResource HackerGreen}" />
        </Style>
        
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource HackerBgAlt}" />
            <Setter Property="Foreground" Value="{StaticResource HackerGreen}" />
            <Setter Property="BorderBrush" Value="{StaticResource HackerGreen}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Application.Resources>
</Application>
