<UserControl x:Class="Views.SuspiciousScanner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900" Background="#000000" Foreground="#00FF00" FontFamily="Consolas">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Suspicious File Scanner" FontSize="24" FontWeight="Bold" Foreground="#00FF00" VerticalAlignment="Center" />
            <Button x:Name="btnSelectFile" Content="Select File to Analyze" Margin="20,0,0,0" Padding="15,5" Background="#FF0000" Foreground="#000000" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="btnSelectFile_Click" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" Background="#0A0A0A" Padding="20">
            <StackPanel>
                <TextBlock Text="Analysis Results" FontSize="18" FontWeight="Bold" Foreground="#008800" Margin="0,0,0,10" />
                <TextBox x:Name="txtResults" IsReadOnly="True" Background="Transparent" Foreground="#00FF00" BorderThickness="0" FontSize="14" TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
