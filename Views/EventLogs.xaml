<UserControl x:Class="Views.EventLogs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900" Background="#000000" Foreground="#00FF00" FontFamily="Consolas">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Event Log Analyzer" FontSize="24" FontWeight="Bold" Foreground="#00FF00" VerticalAlignment="Center" />
            <ComboBox x:Name="cmbLogType" Width="150" Margin="20,0,0,0" Padding="5" VerticalAlignment="Center" SelectedIndex="0">
                <ComboBoxItem Content="System" />
                <ComboBoxItem Content="Security" />
                <ComboBoxItem Content="Application" />
            </ComboBox>
            <Button x:Name="btnLoadLogs" Content="Load Logs" Margin="20,0,0,0" Padding="15,5" Background="#00FF00" Foreground="#000000" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="btnLoadLogs_Click" />
        </StackPanel>

        <DataGrid x:Name="dgLogs" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Background="#0A0A0A" Foreground="#00FF00" RowBackground="#000000" AlternatingRowBackground="#0A0A0A" ColumnHeaderHeight="40">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Time" Binding="{Binding TimeGenerated}" Width="1.5*" />
                <DataGridTextColumn Header="Event ID" Binding="{Binding EventID}" Width="1*" />
                <DataGridTextColumn Header="Level" Binding="{Binding EntryType}" Width="1*" />
                <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="1.5*" />
                <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="4*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
