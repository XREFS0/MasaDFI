<UserControl x:Class="Views.Dashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900" Background="#000000" Foreground="#00FF00" FontFamily="Consolas">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Dashboard Overview" FontSize="24" FontWeight="Bold" Foreground="#00FF00" Margin="0,0,0,20" />

        <!-- Info Cards -->
        <UniformGrid Grid.Row="1" Columns="3" VerticalAlignment="Top" HorizontalAlignment="Stretch">
            
            <!-- USB Devices Card -->
            <Border Background="#0A0A0A" CornerRadius="10" Padding="20" Margin="10">
                <StackPanel>
                    <TextBlock Text="USB Devices Found" FontSize="16" Foreground="#008800" />
                    <TextBlock x:Name="txtUsbCount" Text="0" FontSize="36" FontWeight="Bold" Foreground="#00C896" Margin="0,10,0,0" />
                </StackPanel>
            </Border>

            <!-- Suspicious Files Card -->
            <Border Background="#0A0A0A" CornerRadius="10" Padding="20" Margin="10">
                <StackPanel>
                    <TextBlock Text="Suspicious Files" FontSize="16" Foreground="#008800" />
                    <TextBlock x:Name="txtSuspiciousCount" Text="0" FontSize="36" FontWeight="Bold" Foreground="#FF5E5E" Margin="0,10,0,0" />
                </StackPanel>
            </Border>

            <!-- Browser History Card -->
            <Border Background="#0A0A0A" CornerRadius="10" Padding="20" Margin="10">
                <StackPanel>
                    <TextBlock Text="Browser Records" FontSize="16" Foreground="#008800" />
                    <TextBlock x:Name="txtBrowserCount" Text="0" FontSize="36" FontWeight="Bold" Foreground="#4A90E2" Margin="0,10,0,0" />
                </StackPanel>
            </Border>
            
            <!-- Recovered Files Card -->
            <Border Background="#0A0A0A" CornerRadius="10" Padding="20" Margin="10">
                <StackPanel>
                    <TextBlock Text="Deleted Files Mapped" FontSize="16" Foreground="#008800" />
                    <TextBlock x:Name="txtDeletedCount" Text="0" FontSize="36" FontWeight="Bold" Foreground="#E2A94A" Margin="0,10,0,0" />
                </StackPanel>
            </Border>
            
            <!-- Last Activity Card -->
            <Border Background="#0A0A0A" CornerRadius="10" Padding="20" Margin="10">
                <StackPanel>
                    <TextBlock Text="Recent Events Logged" FontSize="16" Foreground="#008800" />
                    <TextBlock x:Name="txtEventsCount" Text="0" FontSize="36" FontWeight="Bold" Foreground="#B066FF" Margin="0,10,0,0" />
                </StackPanel>
            </Border>
        </UniformGrid>
    </Grid>
</UserControl>
