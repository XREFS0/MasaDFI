<UserControl x:Class="Views.EvidenceExport"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900" Background="#000000" Foreground="#00FF00" FontFamily="Consolas">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Evidence Export &amp; Reporting" FontSize="24" FontWeight="Bold" Foreground="#00FF00" Margin="0,0,0,20" />

        <Border Grid.Row="1" Background="#0A0A0A" Padding="30" HorizontalAlignment="Left" Width="400">
            <StackPanel>
                <TextBlock Text="Case Details" FontSize="18" FontWeight="Bold" Foreground="#008800" Margin="0,0,0,10" />
                
                <TextBlock Text="Case ID:" Foreground="#00FF00" Margin="0,5,0,0"/>
                <TextBox x:Name="txtCaseID" Margin="0,5,0,15" Padding="5" />

                <TextBlock Text="Examiner Name:" Foreground="#00FF00" Margin="0,5,0,0"/>
                <TextBox x:Name="txtExaminer" Margin="0,5,0,15" Padding="5" />

                <TextBlock Text="Report Format:" Foreground="#00FF00" Margin="0,5,0,0"/>
                <ComboBox x:Name="cmbFormat" Margin="0,5,0,20" Padding="5">
                    <ComboBoxItem Content="PDF Document (.pdf)" IsSelected="True" />
                    <ComboBoxItem Content="HTML Report (.html)" />
                    <ComboBoxItem Content="JSON Data (.json)" />
                    <ComboBoxItem Content="CSV Spreadsheet (.csv)" />
                </ComboBox>

                <Button x:Name="btnExport" Content="Generate Report" Padding="10" Background="#00FF00" Foreground="#000000" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="btnExport_Click" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
