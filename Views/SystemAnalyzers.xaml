<UserControl x:Class="Views.SystemAnalyzers"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900" Background="#000000" Foreground="#00FF00" FontFamily="Consolas">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="System Analyzers" FontSize="24" FontWeight="Bold" Foreground="#00FF00" Margin="0,0,0,20" />

        <TabControl Grid.Row="1" Background="#0A0A0A" BorderBrush="#00FF00" Foreground="#00FF00">
            <!-- Processes Tab -->
            <TabItem Header="Running Processes">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button x:Name="btnLoadProcesses" Content="Refresh Processes" Margin="10" Padding="10,5" Width="150" HorizontalAlignment="Left" Background="#00FF00" BorderThickness="0" Cursor="Hand" Click="btnLoadProcesses_Click" />
                    <DataGrid x:Name="dgProcesses" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" RowBackground="#000000" AlternatingRowBackground="#0A0A0A">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PID" Binding="{Binding PID}" Width="0.8*" />
                            <DataGridTextColumn Header="Process Name" Binding="{Binding ProcessName}" Width="2*" />
                            <DataGridTextColumn Header="Memory (MB)" Binding="{Binding MemoryMB}" Width="1*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            
            <!-- Network Tab -->
            <TabItem Header="Network Connections">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button x:Name="btnLoadNetwork" Content="Scan Connections" Margin="10" Padding="10,5" Width="150" HorizontalAlignment="Left" Background="#00FF00" Foreground="#000000" BorderThickness="0" Cursor="Hand" Click="btnLoadNetwork_Click" />
                    <TextBox x:Name="txtNetworkOut" Grid.Row="1" IsReadOnly="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Background="#000000" Foreground="#00FF00" FontFamily="Consolas" Margin="10" Padding="10" />
                </Grid>
            </TabItem>

            <!-- Startup Programs Tab -->
            <TabItem Header="Startup Programs">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button x:Name="btnLoadStartup" Content="Scan Startup Apps" Margin="10" Padding="10,5" Width="150" HorizontalAlignment="Left" Background="#00FF00" Foreground="#000000" BorderThickness="0" Cursor="Hand" Click="btnLoadStartup_Click" />
                    <DataGrid x:Name="dgStartup" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" RowBackground="#000000" AlternatingRowBackground="#0A0A0A">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="1.5*" />
                            <DataGridTextColumn Header="Path / Command" Binding="{Binding Path}" Width="3*" />
                            <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="1*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Screenshots Collector Tab -->
            <TabItem Header="Screenshots">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button x:Name="btnTakeScreenshot" Content="Take Screenshot" Margin="10" Padding="10,5" Width="150" HorizontalAlignment="Left" Background="#00FF00" Foreground="#000000" BorderThickness="0" Cursor="Hand" Click="btnTakeScreenshot_Click" />
                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Margin="10">
                        <Image x:Name="imgScreenshot" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
